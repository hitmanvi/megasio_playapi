APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# APP_WEB_URL=https://example.com  # Frontend web URL for event tracking (defaults to APP_URL)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# 轮换 APP_KEY 后的旧 key 列表（逗号分隔），见 config/app.php
# APP_PREVIOUS_KEYS=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# JWT 密钥（游戏会话等，见 config/app.php）
JWT_SECRET=

# 余额模式：currency=多币种存款 | bundle=双币种捆绑包（GoldCoin / SocialCoin）
APP_CURRENCY=USD
DEPOSIT_BONUS_WAGER_MULTIPLIER=40
BONUS_EXPIRE_DAYS=7

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=megasio_play_api
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# 自定义 S3/MinIO 公网 URL 与端点（可选）
# AWS_URL=
# AWS_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"

# 后台管理 API（/api/x7k9m2p4/*，middleware admin.api，见 config/admin.php）
ADMIN_API_KEY=

# Sopay 支付（config/services.php）
SOPAY_ENDPOINT=
SOPAY_APP_ID=
SOPAY_APP_KEY=
SOPAY_CALLBACK_URL=
SOPAY_RETURN_URL=

# 汇率接口（config/services.php）
EXCHANGE_RATE_ENDPOINT=
EXCHANGE_RATE_API_KEY=

FUNKY_API_URL=
FUNKY_CLIENT_ID=
FUNKY_CLIENT_SECRET=
FUNKY_LANG=
FUNKY_ID=
FUNKY_SECRET=
# Funky 回调 IP 白名单，逗号分隔；不配置则使用代码内默认（config/providers.php）
# FUNKY_IP_WHITELIST=

# 游戏提供商通用：会话 return URL、默认币种、回调限流（config/providers.php）
PROVIDER_RETURN_URL=
DEFAULT_CURRENCY=USD

# Google OAuth (不同客户端使用不同 client_id)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google reCAPTCHA Enterprise（发送验证码等；composer: google/cloud-recaptcha-enterprise，见 config/services.php）
# 文档：https://docs.cloud.google.com/php/docs/reference/cloud-recaptcha-enterprise/latest
RECAPTCHA_ENABLED=false
RECAPTCHA_ENTERPRISE_PROJECT_ID=
RECAPTCHA_ENTERPRISE_SITE_KEY=
# 服务账号 JSON 路径；不配则使用 GOOGLE_APPLICATION_CREDENTIALS / 运行环境默认凭据
# RECAPTCHA_ENTERPRISE_CREDENTIALS=/path/to/service-account.json
# 与前端 token 生成时 action 一致（可选）
# RECAPTCHA_EXPECTED_ACTION=send_verification_code
# 仅当需要按分数拦截时设置（0~1，越高越像真人）；不设置则只校验 token 有效
# RECAPTCHA_MIN_SCORE=0.5

# Kochava Post-Install Tracking (https://support.kochava.com/articles/server-to-server-integration/185-post-install-event-setup)
KOCHAVA_ENABLED=false
KOCHAVA_APP_ID=

# Facebook Conversions API (https://developers.facebook.com/docs/marketing-api/conversions-api/using-the-api)
# Requires facebook/php-business-sdk
FACEBOOK_CONVERSIONS_ENABLED=false
FACEBOOK_PIXEL_ID=
FACEBOOK_CONVERSIONS_ACCESS_TOKEN=

# Customer.io Track API (https://customer.io/docs/api/track/)
CUSTOMER_IO_ENABLED=false
CUSTOMER_IO_SITE_ID=
CUSTOMER_IO_API_KEY=
# 入站 Webhook（仅 unsubscribed 退订 → receive_promotion_email=false），POST /webhooks/customer-io
CUSTOMER_IO_WEBHOOK_ENABLED=false
CUSTOMER_IO_WEBHOOK_SIGNING_SECRET=
# 默认 true：校验 X-CIO-Signature + X-CIO-Timestamp，须配置 SIGNING_SECRET；本地无签名联调可 false
CUSTOMER_IO_WEBHOOK_VERIFY_SIGNATURE=true
# 可选：Customer.io Webhook 来源 IP 白名单（逗号分隔，支持 CIDR）；空表示不校验 IP
CUSTOMER_IO_WEBHOOK_IP_WHITELIST=

# OpenSearch / AWS OpenSearch (统计事件上报)
OPENSEARCH_ENABLED=false
OPENSEARCH_HOSTS=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=megasio

