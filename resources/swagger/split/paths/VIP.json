{
    "\/vip\/levels": {
        "get": {
            "tags": [
                "VIP"
            ],
            "summary": "获取所有VIP等级列表",
            "description": "获取所有启用的VIP等级列表，包括等级信息和所属组信息",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/VipLevelListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "level": "1",
                                            "required_exp": 0,
                                            "description": "初始等级，开启VIP之旅",
                                            "benefits": {
                                                "daily_bonus": 100,
                                                "withdraw_limit": 1000,
                                                "cashback_rate": 0.01
                                            },
                                            "group": {
                                                "id": 1,
                                                "name": "Bronze",
                                                "icon": "vip-bronze",
                                                "card_img": "vip-bronze-card"
                                            }
                                        },
                                        {
                                            "level": "2",
                                            "required_exp": 500,
                                            "description": "累计500经验值可达此等级",
                                            "benefits": {
                                                "daily_bonus": 200,
                                                "withdraw_limit": 3000,
                                                "cashback_rate": 0.02
                                            },
                                            "group": {
                                                "id": 2,
                                                "name": "Silver",
                                                "icon": "vip-silver",
                                                "card_img": "vip-silver-card"
                                            }
                                        }
                                    ],
                                    "meta": []
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/vip\/groups": {
        "get": {
            "tags": [
                "VIP"
            ],
            "summary": "获取所有VIP等级组列表",
            "description": "获取所有启用的VIP等级组列表（分页）",
            "parameters": [
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "schema": {
                        "type": "integer",
                        "default": 1,
                        "minimum": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/VipLevelGroupListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "name": "Bronze",
                                            "icon": "vip-bronze",
                                            "card_img": "vip-bronze-card"
                                        },
                                        {
                                            "id": 2,
                                            "name": "Silver",
                                            "icon": "vip-silver",
                                            "card_img": "vip-silver-card"
                                        },
                                        {
                                            "id": 3,
                                            "name": "Gold",
                                            "icon": "vip-gold",
                                            "card_img": "vip-gold-card"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "last_page": 1,
                                        "total": 3
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "\/vip\/setting": {
        "get": {
            "tags": [
                "VIP"
            ],
            "summary": "获取 VIP 分组配置",
            "description": "获取 group=vip 的 setting 配置，包含 supported_game_categories、weekly_cashback、monthly_cashback 等",
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": "Success"
                                    },
                                    "data": {
                                        "type": "object",
                                        "description": "VIP 分组配置",
                                        "properties": {
                                            "vip": {
                                                "type": "object",
                                                "properties": {
                                                    "supported_game_categories": {
                                                        "type": "array",
                                                        "items": {
                                                            "type": "integer"
                                                        },
                                                        "description": "支持 cashback 的游戏分类 ID 数组"
                                                    },
                                                    "weekly_cashback": {
                                                        "type": "object",
                                                        "properties": {
                                                            "enabled": {
                                                                "type": "boolean",
                                                                "description": "周返现是否开启"
                                                            }
                                                        }
                                                    },
                                                    "monthly_cashback": {
                                                        "type": "object",
                                                        "properties": {
                                                            "enabled": {
                                                                "type": "boolean",
                                                                "description": "月返现是否开启"
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "vip": {
                                        "supported_game_categories": [
                                            1
                                        ],
                                        "weekly_cashback": {
                                            "enabled": true
                                        },
                                        "monthly_cashback": {
                                            "enabled": true
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
