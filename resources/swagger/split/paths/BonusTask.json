{
    "\/bonus-tasks": {
        "get": {
            "tags": [
                "BonusTask"
            ],
            "summary": "获取奖励任务列表",
            "description": "获取当前用户的所有奖励任务列表，支持按状态过滤，按创建时间倒序返回。",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "status",
                    "in": "query",
                    "required": false,
                    "description": "任务状态过滤（可选，支持单个值或数组，例如：status=pending 或 status[]=pending&status[]=active）",
                    "schema": {
                        "oneOf": [
                            {
                                "type": "string",
                                "enum": [
                                    "pending",
                                    "active",
                                    "completed",
                                    "claimed",
                                    "expired",
                                    "cancelled",
                                    "depleted"
                                ]
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": [
                                        "pending",
                                        "active",
                                        "completed",
                                        "claimed",
                                        "expired",
                                        "cancelled",
                                        "depleted"
                                    ]
                                }
                            }
                        ]
                    },
                    "style": "form",
                    "explode": true
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "required": false,
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "required": false,
                    "description": "页码",
                    "schema": {
                        "type": "integer",
                        "default": 1,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/BonusTaskListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "task_no": "FIRST_DEPOSIT_BONUS",
                                            "bonus_name": "First Deposit Bonus",
                                            "cap_bonus": 100,
                                            "base_bonus": 50,
                                            "last_bonus": 100,
                                            "need_wager": 500,
                                            "wager": 500,
                                            "status": "completed",
                                            "currency": "USD",
                                            "expired_at": "2026-02-15T10:00:00Z",
                                            "progress_percent": 100,
                                            "created_at": "2026-01-15 10:00:00",
                                            "updated_at": "2026-01-15 12:00:00"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "last_page": 5,
                                        "total": 100
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "400": {
                    "description": "参数验证失败",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/bonus-tasks\/claimable": {
