                                "$ref": "#\/components\/schemas\/BonusTaskListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": [
                                    {
                                        "id": 1,
                                        "task_no": "TASK001",
                                        "bonus_name": "首充奖励",
