    "\/bonus-tasks\/{id}\/claim": {
        "post": {
            "tags": [
                "BonusTask"
            ],
            "summary": "领取奖励任务奖励",
            "description": "领取指定奖励任务的奖励，奖励金额为 min(cap_bonus, last_bonus)。任务必须已完成，已完成的任务不受过期时间限制。",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "奖励任务ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "领取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/BonusTaskClaimResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "id": 1,
                                    "task_no": "TASK001",
                                    "bonus_name": "首充奖励",
                                    "cap_bonus": 100,
                                    "base_bonus": 50,
                                    "last_bonus": 100,
                                    "need_wager": 500,
                                    "wager": 500,
                                    "status": "claimed",
                                    "currency": "USD",
                                    "expired_at": "2026-02-15T10:00:00Z",
                                    "progress_percent": 100,
                                    "claim_amount": 100,
                                    "created_at": "2026-01-15 10:00:00",
