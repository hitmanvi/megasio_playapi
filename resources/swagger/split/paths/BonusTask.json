    "\/bonus-tasks\/{id}\/active": {
        "post": {
            "tags": [
                "BonusTask"
            ],
            "summary": "激活奖励任务",
            "description": "激活指定的奖励任务。只有 pending 状态且未过期的任务可以被激活。如果用户已有其他激活的任务，会自动将其变为 pending 状态，然后激活新任务。",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "奖励任务ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "激活成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/BonusTaskResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "id": 1,
                                    "task_no": "TASK001",
                                    "bonus_name": "首充奖励",
                                    "cap_bonus": 100,
                                    "base_bonus": 50,
                                    "last_bonus": 100,
                                    "need_wager": 500,
                                    "wager": 0,
                                    "status": "active",
                                    "currency": "USD",
                                    "expired_at": "2026-02-15T10:00:00Z",
                                    "progress_percent": 0,
                                    "created_at": "2026-01-15 10:00:00",
                                    "updated_at": "2026-01-15 12:00:00"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "奖励任务不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "400": {
                    "description": "操作不允许（任务不是 pending 状态或已过期）",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/bonus-tasks\/deposit-bonus-status": {
        "get": {
            "tags": [
                "BonusTask"
            ],
            "summary": "获取用户充值奖励状态",
            "description": "获取用户充值奖励状态。如果首充\/二充\/三充未完成，返回当前可以获得的第一个奖励；如果都完成了，返回每日充值奖励状态。",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/DepositBonusStatusResponse"
                            },
                            "examples": {
                                "first_second_third": {
                                    "summary": "首充\/二充\/三充奖励",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "type": "first_second_third",
                                            "current_reward": {
                                                "type": "first_deposit_bonus",
                                                "name": "First Deposit Bonus",
