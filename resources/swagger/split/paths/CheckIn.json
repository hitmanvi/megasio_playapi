{
    "\/check-ins": {
        "post": {
            "tags": [
                "CheckIn"
            ],
            "summary": "用户签到",
            "description": "每日签到功能。普通签到每天只能签到一次。额外签到（bonus）需要当天使用特定支付通道充值成功后才能使用，每天也只能使用一次额外签到。额外签到不影响连续签到天数，奖励档位与当天普通签到相同。",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "requestBody": {
                "required": false,
                "content": {
                    "application\/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "bonus": {
                                    "type": "boolean",
                                    "description": "是否为额外签到。true 表示额外签到，false 或不传表示普通签到。额外签到需要当天使用配置的支付通道充值成功后才能使用。",
                                    "default": false
                                }
                            }
                        },
                        "examples": {
                            "normal": {
                                "summary": "普通签到",
                                "value": {
                                    "bonus": false
                                }
                            },
                            "bonus": {
                                "summary": "额外签到",
                                "value": {
                                    "bonus": true
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "签到成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/CheckInResponse"
                            },
                            "examples": {
                                "normal": {
                                    "summary": "普通签到成功",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "id": 1,
                                            "check_in_date": "2026-01-12",
                                            "consecutive_days": 5,
                                            "reward_day": 5,
                                            "is_bonus_check_in": false,
                                            "rewards_granted": [
                                                {
                                                    "type": "USD",
                                                    "amount": 0.25,
                                                    "description": "Check-in reward day 5"
                                                }
                                            ],
                                            "created_at": "2026-01-12T09:00:00+00:00"
                                        }
                                    }
                                },
                                "bonus": {
                                    "summary": "额外签到成功",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "id": 2,
                                            "check_in_date": "2026-01-12",
                                            "consecutive_days": 5,
                                            "reward_day": 5,
                                            "is_bonus_check_in": true,
                                            "rewards_granted": [
                                                {
                                                    "type": "USD",
                                                    "amount": 0.25,
                                                    "description": "Check-in reward day 5"
                                                }
                                            ],
                                            "created_at": "2026-01-12T15:00:00+00:00"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "400": {
                    "description": "签到失败",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            },
                            "examples": {
                                "already_checked_in": {
                                    "summary": "今日已签到",
                                    "value": {
                                        "code": 1001,
                                        "errmsg": "Already checked in today",
                                        "data": null
                                    }
                                },
                                "bonus_already_used": {
                                    "summary": "今日已使用额外签到",
                                    "value": {
                                        "code": 1001,
                                        "errmsg": "Bonus check-in already used today",
                                        "data": null
                                    }
                                },
                                "bonus_not_available": {
                                    "summary": "额外签到不可用（未使用指定支付通道充值）",
                                    "value": {
                                        "code": 1001,
                                        "errmsg": "Bonus check-in not available. Please deposit using eligible payment channels.",
                                        "data": null
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                }
            }
        }
    },
    "\/check-ins\/status": {
        "get": {
            "tags": [
                "CheckIn"
            ],
            "summary": "获取签到状态",
            "description": "获取用户当前签到状态，包括今日是否已签到、连续签到天数、总签到天数",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/CheckInStatusResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "checked_in_today": true,
                                    "consecutive_days": 5,
                                    "total_days": 30,
                                    "next_check_in_at": "2026-01-13T09:00:00+00:00",
                                    "today_check_in": {
                                        "id": 1,
                                        "check_in_date": "2026-01-12",
                                        "consecutive_days": 5,
                                        "created_at": "2026-01-12T09:00:00+00:00"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                }
            }
        }
    },
    "\/check-ins\/history": {
        "get": {
            "tags": [
                "CheckIn"
            ],
            "summary": "获取签到历史",
            "description": "获取用户签到历史记录（分页）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "schema": {
                        "type": "integer",
                        "default": 1,
                        "minimum": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/CheckInHistoryResponse"
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                }
            }
        }
    },
    "\/check-ins\/config": {
        "get": {
            "tags": [
                "CheckIn"
            ],
            "summary": "获取签到配置",
            "description": "获取签到奖励配置信息，包括奖励金额、币种、额外签到通道等",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/CheckInConfigResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "enabled": true,
                                    "method": "fixed",
                                    "currency": "USD",
                                    "rewards": [
                                        0.25,
                                        0.25,
                                        0.25,
                                        0.25,
                                        0.25,
                                        0.25,
                                        0.25
                                    ],
                                    "payment_method_ids": [
                                        1,
                                        2,
                                        3
                                    ]
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
