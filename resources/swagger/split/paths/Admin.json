{
    "\/x7k9m2p4\/stats\/user-deposit-withdraw": {
        "get": {
            "tags": [
                "Admin"
            ],
            "summary": "获取用户充提金额汇总",
            "description": "从 OpenSearch 获取用户充提金额汇总，每个用户一条数据。支持按 uid、充提日期、agent_id、agent_link_id 过滤，支持时区（UTC+8、UTC-4 等格式）。",
            "security": [
                {
                    "apiKeyAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "uid",
                    "in": "query",
                    "required": false,
                    "description": "按用户 uid 过滤",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "date_from",
                    "in": "query",
                    "required": false,
                    "description": "充提日期起（Y-m-d）",
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "date_to",
                    "in": "query",
                    "required": false,
                    "description": "充提日期止（Y-m-d）",
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "agent_id",
                    "in": "query",
                    "required": false,
                    "description": "按 agent_id 过滤",
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "agent_link_id",
                    "in": "query",
                    "required": false,
                    "description": "按 agent_link_id 过滤",
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "timezone",
                    "in": "query",
                    "required": false,
                    "description": "时区，默认 UTC。支持 UTC+8、UTC-4、UTC+4:30 等格式",
                    "schema": {
                        "type": "string",
                        "default": "UTC"
                    }
                },
                {
                    "name": "size",
                    "in": "query",
                    "required": false,
                    "description": "返回用户数上限，默认 10000",
                    "schema": {
                        "type": "integer",
                        "default": 10000
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/UserDepositWithdrawStatsResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "data": [
                                        {
                                            "user_id": 1,
                                            "deposit_total": 1000.5,
                                            "withdraw_total": 200.0,
                                            "deposit_completed_total": 800.0,
                                            "withdraw_completed_total": 200.0
                                        }
                                    ],
                                    "total": 1
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权（API Key 无效或缺失）",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "500": {
                    "description": "OpenSearch 未启用或连接失败",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
