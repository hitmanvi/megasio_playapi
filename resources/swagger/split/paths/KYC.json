{
    "\/kyc": {
        "get": {
            "tags": [
                "KYC"
            ],
            "summary": "获取 KYC 信息",
            "description": "获取当前用户的 KYC 认证信息",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SuccessResponse"
                            },
                            "examples": {
                                "has_kyc": {
                                    "summary": "已提交 KYC",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "name": "张三",
                                            "birthdate": "1990-01-01",
                                            "document_front": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_front.jpg",
                                            "document_back": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_back.jpg",
                                            "document_number": "123456789012345678",
                                            "selfie": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/selfie.jpg",
                                            "status": "pending",
                                            "reject_reason": null,
                                            "created_at": "2024-01-01T00:00:00.000000Z",
                                            "updated_at": "2024-01-01T00:00:00.000000Z"
                                        }
                                    }
                                },
                                "no_kyc": {
                                    "summary": "未提交 KYC",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": null
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "KYC"
            ],
            "summary": "提交\/更新 KYC 基本信息（初审）",
            "description": "提交或更新 KYC 基本信息。初审通过后才能提交高级认证。状态流程：pending -> approved\/rejected（初审）-> advanced_pending -> advanced_approved\/advanced_rejected（高级）-> enhanced_pending -> enhanced_approved\/enhanced_rejected（增强）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application\/json": {
                        "schema": {
                            "$ref": "#\/components\/schemas\/KycRequest"
                        },
                        "example": {
                            "name": "张三",
                            "birthdate": "1990-01-01",
                            "document_front": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_front.jpg",
                            "document_back": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_back.jpg",
                            "document_number": "123456789012345678"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "提交成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SuccessResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "name": "张三",
                                    "birthdate": "1990-01-01",
                                    "document_front": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_front.jpg",
                                    "document_back": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_back.jpg",
                                    "document_number": "123456789012345678",
                                    "selfie": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/selfie.jpg",
                                    "status": "pending",
                                    "reject_reason": null,
                                    "created_at": "2024-01-01T00:00:00.000000Z",
                                    "updated_at": "2024-01-01T00:00:00.000000Z"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "验证失败",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/kyc\/advanced": {
        "post": {
            "tags": [
                "KYC"
            ],
            "summary": "提交高级认证",
            "description": "提交高级认证（如自拍等）。仅在初审通过（status=approved）或高级认证被拒绝（status=advanced_rejected）时可提交。状态：pending\/approved\/rejected（初审）-> advanced_pending\/advanced_approved\/advanced_rejected（高级）-> enhanced_pending\/enhanced_approved\/enhanced_rejected（增强）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application\/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "selfie"
                            ],
                            "properties": {
                                "selfie": {
                                    "type": "string",
                                    "format": "uri",
                                    "maxLength": 500,
                                    "description": "自拍照片 URL"
                                }
                            }
                        },
                        "example": {
                            "selfie": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/selfie.jpg"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "提交成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SuccessResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "name": "张三",
                                    "birthdate": "1990-01-01",
                                    "document_front": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_front.jpg",
                                    "document_back": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/doc_back.jpg",
                                    "document_number": "123456789012345678",
                                    "selfie": "https:\/\/s3.amazonaws.com\/bucket\/uploads\/selfie.jpg",
                                    "status": "advanced_pending",
                                    "reject_reason": null,
                                    "created_at": "2024-01-01T00:00:00.000000Z",
                                    "updated_at": "2024-01-01T00:00:00.000000Z"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "403": {
                    "description": "当前状态不允许提交高级认证",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            },
                            "example": {
                                "code": 4003,
                                "errmsg": "Cannot submit advanced verification at current status",
                                "data": null
                            }
                        }
                    }
                },
                "404": {
                    "description": "未找到 KYC 记录",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            },
                            "example": {
                                "code": 1004,
                                "errmsg": "KYC not found, please submit basic info first",
                                "data": null
                            }
                        }
                    }
                }
            }
        }
    }
}
