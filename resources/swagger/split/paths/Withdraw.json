{
    "\/withdraws": {
        "get": {
            "tags": [
                "Withdraw"
            ],
            "summary": "获取提款订单列表",
            "description": "获取当前用户的提款订单列表，支持按状态、支付状态、货币类型、支付方式筛选",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "status",
                    "in": "query",
                    "description": "订单状态筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "PROCESSING",
                            "COMPLETED",
                            "FAILED",
                            "CANCELLED",
                            "REJECTED"
                        ]
                    }
                },
                {
                    "name": "pay_status",
                    "in": "query",
                    "description": "支付状态筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "PAID",
                            "FAILED",
                            "CANCELLED"
                        ]
                    }
                },
                {
                    "name": "currency",
                    "in": "query",
                    "description": "货币类型筛选",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "payment_method_id",
                    "in": "query",
                    "description": "支付方式ID筛选",
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取提款订单列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WithdrawListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "order_no": "WTD01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                            "out_trade_no": "SOPAY123456",
                                            "currency": "USD",
                                            "amount": 1000,
                                            "actual_amount": null,
                                            "fee": 0,
                                            "payment_method": {
                                                "key": "ach_usd_withdraw",
                                                "name": "ach",
                                                "display_name": "ACH Transfer",
                                                "icon": "ach.svg"
                                            },
                                            "status": "PENDING",
                                            "pay_status": "PENDING",
                                            "approved": false,
                                            "completed_at": null,
                                            "created_at": "2024-01-01 12:00:00"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "last_page": 1,
                                        "total": 1
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Withdraw"
            ],
            "summary": "创建提款订单",
            "description": "创建新的提款订单",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application\/json": {
                        "schema": {
                            "$ref": "#\/components\/schemas\/CreateWithdrawRequest"
                        },
                        "example": {
                            "payment_method_id": 1,
                            "amount": 1000,
                            "currency": "USD",
                            "withdraw_info": {
                                "ua": "h5",
                                "channel_id": 13
                            },
                            "extra_info": {
                                "ifsc": "IDJF0123123",
                                "name": "John Doe",
                                "email": "john@example.com",
                                "phone": "1234567890",
                                "bank_account": "123456789012"
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "创建提款订单成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WithdrawDetailResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "order_no": "WTD01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                    "currency": "USD",
                                    "amount": 1000,
                                    "actual_amount": null,
                                    "fee": 0,
                                    "payment_method": {
                                        "key": "ach_usd_withdraw",
                                        "name": "ach",
                                        "display_name": "ACH Transfer",
                                        "icon": "ach.svg"
                                    },
                                    "status": "PENDING",
                                    "pay_status": "PENDING",
                                    "approved": false,
                                    "completed_at": null,
                                    "created_at": "2024-01-01 12:00:00",
                                    "updated_at": "2024-01-01 12:00:00",
                                    "withdraw_info": {
                                        "ua": "h5",
                                        "channel_id": 13
                                    },
                                    "extra_info": {
                                        "ifsc": "IDJF0123123",
                                        "name": "John Doe",
                                        "email": "john@example.com",
                                        "phone": "1234567890",
                                        "bank_account": "123456789012"
                                    },
                                    "user_ip": "192.168.1.1"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "支付方式不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/withdraws\/statuses": {
        "get": {
            "tags": [
                "Withdraw"
            ],
            "summary": "获取提款订单状态集合",
            "description": "获取所有可用的提款订单状态列表",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": "Success"
                                    },
                                    "data": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "enum": [
                                                "PENDING",
                                                "PROCESSING",
                                                "COMPLETED",
                                                "FAILED",
                                                "CANCELLED",
                                                "REJECTED"
                                            ]
                                        },
                                        "example": [
                                            "PENDING",
                                            "PROCESSING",
                                            "COMPLETED",
                                            "FAILED",
                                            "CANCELLED",
                                            "REJECTED"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/withdraws\/form-fields": {
        "get": {
            "tags": [
                "Withdraw"
            ],
            "summary": "获取提款表单字段配置",
            "description": "根据支付方式和金额获取用户需要填写的表单字段",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "payment_method_id",
                    "in": "query",
                    "required": true,
                    "description": "支付方式ID",
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "amount",
                    "in": "query",
                    "required": true,
                    "description": "金额",
                    "schema": {
                        "type": "number",
                        "minimum": 0.01
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取表单字段成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WithdrawFormFieldsResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "channel_id": "123",
                                    "withdraw_fields": [
                                        {
                                            "field": "bank_account",
                                            "require": true,
                                            "type": "string",
                                            "title": "bank_account",
                                            "placeholder": "bank_account"
                                        },
                                        {
                                            "field": "ifsc",
                                            "require": true,
                                            "type": "string",
                                            "title": "ifsc",
                                            "placeholder": "ifsc"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "支付方式不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/withdraws\/{orderNo}": {
        "get": {
            "tags": [
                "Withdraw"
            ],
            "summary": "获取提款订单详情",
            "description": "根据订单号获取提款订单的详细信息",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "orderNo",
                    "in": "path",
                    "required": true,
                    "description": "订单号",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取提款订单详情成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WithdrawDetailResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "order_no": "WTD01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                    "out_trade_no": "SOPAY123456",
                                    "currency": "USD",
                                    "amount": 1000,
                                    "actual_amount": 1000,
                                    "fee": 0,
                                    "payment_method": {
                                        "key": "ach_usd_withdraw",
                                        "name": "ach",
                                        "display_name": "ACH Transfer",
                                        "icon": "ach.svg"
                                    },
                                    "status": "COMPLETED",
                                    "pay_status": "PAID",
                                    "approved": true,
                                    "user_ip": "192.168.1.1",
                                    "completed_at": "2024-01-01 12:30:00",
                                    "created_at": "2024-01-01 12:00:00",
                                    "updated_at": "2024-01-01 12:30:00",
                                    "withdraw_info": {
                                        "ua": "h5",
                                        "channel_id": 13
                                    },
                                    "extra_info": {
                                        "ifsc": "IDJF0123123",
                                        "name": "John Doe",
                                        "email": "john@example.com",
                                        "phone": "1234567890",
                                        "bank_account": "123456789012"
                                    },
                                    "note": "Withdrawal request"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "提款订单不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
