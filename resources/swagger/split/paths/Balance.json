{
    "\/balances": {
        "get": {
            "tags": [
                "Balance"
            ],
            "summary": "获取用户余额列表",
            "description": "获取当前用户的所有货币余额。如果用户设置了展示货币偏好，则只返回用户选择的货币余额",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取余额列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/BalanceListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "user_id": 1,
                                            "currency": "USD",
                                            "available": 1000.5,
                                            "frozen": 200,
                                            "version": 1
                                        }
                                    ],
                                    "meta": []
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/balances\/{currency}": {
        "get": {
            "tags": [
                "Balance"
            ],
            "summary": "获取指定货币的余额",
            "description": "获取当前用户指定货币的余额信息",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "currency",
                    "in": "path",
                    "required": true,
                    "description": "货币类型",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取余额成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/BalanceResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "available": 1000.5,
                                    "frozen": 200,
                                    "currency": "USD"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
