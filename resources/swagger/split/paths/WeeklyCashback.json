{
    "\/weekly-cashbacks\/claimable": {
        "get": {
            "tags": [
                "WeeklyCashback"
            ],
            "summary": "获取可领取的 Cashback",
            "description": "获取用户上周可领取的 cashback（单个）。无记录返回 data: null。同时会将非上周的 claimable 记录标记为过期。需 VIP 配置 weekly_cashback.enabled=true 才会产生 cashback",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WeeklyCashbackClaimableResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "no": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                    "period": 202605,
                                    "currency": "USD",
                                    "wager": 1000,
                                    "payout": 900,
                                    "status": "claimable",
                                    "rate": 0.05,
                                    "amount": 50,
                                    "claimed_at": null,
                                    "created_at": "2026-02-01 10:00:00",
                                    "updated_at": "2026-02-05 10:00:00"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/weekly-cashbacks\/{no}": {
        "get": {
            "tags": [
                "WeeklyCashback"
            ],
            "summary": "获取 Cashback 详情",
            "description": "通过 no（ULID）获取指定 cashback 详情",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "no",
                    "in": "path",
                    "required": true,
                    "description": "Cashback 标识（26 位 ULID）",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WeeklyCashbackResponse"
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Cashback 不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            },
                            "example": {
                                "code": 4010,
                                "errmsg": "Weekly cashback not found",
                                "data": null
                            }
                        }
                    }
                }
            }
        }
    },
    "\/weekly-cashbacks\/{no}\/claim": {
        "post": {
            "tags": [
                "WeeklyCashback"
            ],
            "summary": "领取 Cashback",
            "description": "领取指定 cashback，金额将入账到用户余额",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "no",
                    "in": "path",
                    "required": true,
                    "description": "Cashback 标识（26 位 ULID）",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "领取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/WeeklyCashbackClaimResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "no": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                    "period": 202605,
                                    "currency": "USD",
                                    "wager": 1000,
                                    "payout": 900,
                                    "status": "claimed",
                                    "rate": 0.05,
                                    "amount": 50,
                                    "claimed_at": "2026-02-05 12:00:00",
                                    "created_at": "2026-02-01 10:00:00",
                                    "updated_at": "2026-02-05 12:00:00",
                                    "claim_amount": 50
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "400": {
                    "description": "业务错误",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            },
                            "examples": {
                                "not_found": {
                                    "summary": "Cashback 不存在",
                                    "value": {
                                        "code": 4010,
                                        "errmsg": "Weekly cashback not found",
                                        "data": null
                                    }
                                },
                                "not_claimable": {
                                    "summary": "不可领取",
                                    "value": {
                                        "code": 4011,
                                        "errmsg": "Weekly cashback is not claimable",
                                        "data": null
                                    }
                                },
                                "no_amount": {
                                    "summary": "无可领取金额",
                                    "value": {
                                        "code": 4012,
                                        "errmsg": "No amount to claim",
                                        "data": null
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
