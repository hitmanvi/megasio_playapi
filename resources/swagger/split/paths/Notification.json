{
    "\/notifications": {
        "get": {
            "tags": [
                "Notification"
            ],
            "summary": "获取通知列表",
            "description": "获取当前用户的通知列表（游标分页），支持按类型、分类和阅读状态筛选",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "type",
                    "in": "query",
                    "description": "消息类型：system（系统消息）、user（用户消息）",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "system",
                            "user"
                        ],
                        "nullable": true
                    }
                },
                {
                    "name": "category",
                    "in": "query",
                    "description": "消息分类：deposit_success（充值成功）、withdraw_success（提现成功）、vip_level_up（VIP等级提升）等",
                    "schema": {
                        "type": "string",
                        "nullable": true
                    }
                },
                {
                    "name": "read",
                    "in": "query",
                    "description": "阅读状态：true（已读）、false（未读）",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "true",
                            "false"
                        ],
                        "nullable": true
                    }
                },
                {
                    "name": "last_id",
                    "in": "query",
                    "description": "游标分页：上一页返回的最后一个通知ID，用于获取下一页数据",
                    "schema": {
                        "type": "integer",
                        "nullable": true
                    }
                },
                {
                    "name": "limit",
                    "in": "query",
                    "description": "每页数量（最大100）",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "maximum": 100
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/NotificationListResponse"
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "\/notifications\/unread-count": {
        "get": {
            "tags": [
                "Notification"
            ],
            "summary": "获取未读通知数量",
            "description": "获取当前用户的未读通知数量统计",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/UnreadCountResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "user_unread_count": 5,
                                    "system_unread_count": 2,
                                    "total_unread_count": 7
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "\/notifications\/{id}": {
        "get": {
            "tags": [
                "Notification"
            ],
            "summary": "获取通知详情",
            "description": "根据ID获取通知详情，查看时会自动标记为已读",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "通知ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/NotificationResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "id": 1,
                                    "type": "user",
                                    "category": "deposit_success",
                                    "title": "充值成功",
                                    "content": "您的充值已成功到账，金额：100.00 USD",
                                    "data": {
                                        "amount": 100,
                                        "currency": "USD",
                                        "order_no": "DEP20260128001"
                                    },
                                    "read_at": "2026-01-28T10:30:00.000000Z",
                                    "is_read": true,
                                    "created_at": "2026-01-28T10:00:00.000000Z"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                },
                "403": {
                    "description": "无权限",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                },
                "404": {
                    "description": "通知不存在",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "\/notifications\/{id}\/read": {
        "put": {
            "tags": [
                "Notification"
            ],
            "summary": "标记通知为已读",
            "description": "将指定的通知标记为已读",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "通知ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "标记成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/NotificationResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "id": 1,
                                    "type": "user",
                                    "category": "deposit_success",
                                    "title": "deposit",
                                    "content": "$100.00 credited to your game balance.",
                                    "data": {
                                        "amount": 100,
                                        "currency": "USD",
                                        "order_no": "DEP20260128001"
                                    },
                                    "read_at": "2026-01-28T10:30:00.000000Z",
                                    "is_read": true,
                                    "created_at": "2026-01-28T10:00:00.000000Z"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                },
                "403": {
                    "description": "无权限",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                },
                "404": {
                    "description": "通知不存在",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "\/notifications\/mark-all-read": {
        "put": {
            "tags": [
                "Notification"
            ],
            "summary": "批量标记为已读",
            "description": "批量将所有未读通知标记为已读，支持按类型筛选",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "type",
                    "in": "query",
                    "description": "消息类型：system（系统消息）、user（用户消息）",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "system",
                            "user"
                        ],
                        "nullable": true
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "标记成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": "Success"
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "message": {
                                                "type": "string",
                                                "example": "Marked 10 notifications as read"
                                            },
                                            "count": {
                                                "type": "integer",
                                                "example": 10
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "$ref": "#\/components\/schemas\/ErrorResponse"
                        }
                    }
                }
            }
        }
    }
}
