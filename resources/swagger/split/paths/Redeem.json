{
    "\/redeems": {
        "get": {
            "tags": [
                "Redeem"
            ],
            "summary": "获取兑换记录列表",
            "description": "获取当前用户的SC兑换USD记录（仅在bundle模式下可用）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "status",
                    "in": "query",
                    "description": "订单状态筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "PROCESSING",
                            "COMPLETED",
                            "FAILED",
                            "CANCELLED",
                            "REJECTED"
                        ]
                    }
                },
                {
                    "name": "pay_status",
                    "in": "query",
                    "description": "支付状态筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "PAID",
                            "FAILED",
                            "CANCELLED"
                        ]
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#\/components\/schemas\/Redeem"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer"
                                                    },
                                                    "last_page": {
                                                        "type": "integer"
                                                    },
                                                    "total": {
                                                        "type": "integer"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                }
            }
        },
        "post": {
            "tags": [
                "Redeem"
            ],
            "summary": "创建兑换订单",
            "description": "创建SC兑换USD的兑换订单",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application\/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "sc_amount",
                                "payment_method_id"
                            ],
                            "properties": {
                                "sc_amount": {
                                    "type": "number",
                                    "description": "要兑换的SC数量"
                                },
                                "payment_method_id": {
                                    "type": "integer",
                                    "description": "提现支付方式ID"
                                },
                                "withdraw_info": {
                                    "type": "object",
                                    "description": "提现信息"
                                },
                                "extra_info": {
                                    "type": "object",
                                    "description": "额外信息"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "创建成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "data": {
                                        "$ref": "#\/components\/schemas\/Redeem"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                },
                "400": {
                    "description": "参数错误或余额不足"
                }
            }
        }
    },
    "\/redeems\/statuses": {
        "get": {
            "tags": [
                "Redeem"
            ],
            "summary": "获取兑换订单状态集合",
            "description": "获取所有可用的兑换订单状态列表",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": "Success"
                                    },
                                    "data": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "enum": [
                                                "PENDING",
                                                "PROCESSING",
                                                "COMPLETED",
                                                "FAILED",
                                                "CANCELLED",
                                                "REJECTED"
                                            ]
                                        },
                                        "example": [
                                            "PENDING",
                                            "PROCESSING",
                                            "COMPLETED",
                                            "FAILED",
                                            "CANCELLED",
                                            "REJECTED"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/redeems\/exchange-rate": {
        "get": {
            "tags": [
                "Redeem"
            ],
            "summary": "获取兑换汇率",
            "description": "获取当前SC到USD的兑换汇率",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "from": {
                                                "type": "string",
                                                "example": "SC"
                                            },
                                            "to": {
                                                "type": "string",
                                                "example": "USD"
                                            },
                                            "rate": {
                                                "type": "number",
                                                "example": 1
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                }
            }
        }
    },
    "\/redeems\/form-fields": {
        "get": {
            "tags": [
                "Redeem"
            ],
            "summary": "获取兑换表单字段",
            "description": "获取创建兑换订单时需要填写的表单字段",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "sc_amount",
                    "in": "query",
                    "required": true,
                    "description": "要兑换的SC数量",
                    "schema": {
                        "type": "number"
                    }
                },
                {
                    "name": "payment_method_id",
                    "in": "query",
                    "required": true,
                    "description": "支付方式ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "data": {
                                        "type": "object",
                                        "description": "表单字段配置"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                },
                "404": {
                    "description": "支付方式不存在"
                }
            }
        }
    },
    "\/redeems\/{orderNo}": {
        "get": {
            "tags": [
                "Redeem"
            ],
            "summary": "获取兑换订单详情",
            "description": "获取指定订单号的兑换订单详情",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "orderNo",
                    "in": "path",
                    "required": true,
                    "description": "订单号",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "data": {
                                        "$ref": "#\/components\/schemas\/Redeem"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权"
                },
                "404": {
                    "description": "订单不存在"
                }
            }
        }
    }
}
