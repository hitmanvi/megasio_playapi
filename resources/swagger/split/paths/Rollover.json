{
    "\/rollovers\/types": {
        "get": {
            "tags": [
                "Rollover"
            ],
            "summary": "获取 Rollover 类型列表",
            "description": "获取可用的 Rollover 来源类型列表",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取类型列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/RolloverTypesResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": [
                                    "deposit",
                                    "bonus",
                                    "reward",
                                    "airdrop"
                                ]
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/rollovers": {
        "get": {
            "tags": [
                "Rollover"
            ],
            "summary": "获取 Rollover 列表",
            "description": "获取当前用户的 Rollover 列表，支持按货币、状态和来源类型过滤",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "currency",
                    "in": "query",
                    "description": "货币类型筛选",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "状态筛选（pending, active, completed），支持数组格式",
                    "schema": {
                        "oneOf": [
                            {
                                "type": "string",
                                "enum": [
                                    "pending",
                                    "active",
                                    "completed"
                                ]
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": [
                                        "pending",
                                        "active",
                                        "completed"
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "name": "source_type",
                    "in": "query",
                    "description": "来源类型筛选（deposit, bonus, reward, airdrop），支持数组格式",
                    "schema": {
                        "oneOf": [
                            {
                                "type": "string",
                                "enum": [
                                    "deposit",
                                    "bonus",
                                    "reward",
                                    "airdrop"
                                ]
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": [
                                        "deposit",
                                        "bonus",
                                        "reward",
                                        "airdrop"
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "schema": {
                        "type": "integer",
                        "default": 1,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取 Rollover 列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/RolloverListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "source_type": "deposit",
                                            "related_id": 123,
                                            "currency": "USD",
                                            "amount": 100,
                                            "required_wager": 100,
                                            "current_wager": 50,
                                            "status": "active",
                                            "progress_percent": 50,
                                            "completed_at": null,
                                            "created_at": "2026-02-12 10:00:00",
                                            "updated_at": "2026-02-12 10:00:00"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "per_page": 20,
                                        "total": 1,
                                        "last_page": 1
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/rollovers\/{id}": {
        "get": {
            "tags": [
                "Rollover"
            ],
            "summary": "获取 Rollover 详情",
            "description": "获取指定 ID 的 Rollover 详情",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "Rollover ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取 Rollover 详情成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/RolloverResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "id": 1,
                                    "source_type": "deposit",
                                    "related_id": 123,
                                    "currency": "USD",
                                    "amount": 100,
                                    "required_wager": 100,
                                    "current_wager": 50,
                                    "status": "active",
                                    "progress_percent": 50,
                                    "completed_at": null,
                                    "created_at": "2026-02-12 10:00:00",
                                    "updated_at": "2026-02-12 10:00:00"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Rollover 不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
