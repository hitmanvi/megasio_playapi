{
    "\/invitations\/stats": {
        "get": {
            "tags": [
                "Invitation"
            ],
            "summary": "获取邀请统计数据",
            "description": "获取当前用户的邀请统计数据，包括总邀请人数、活跃邀请人数和获得的总奖励",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/InvitationStatsResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "total_invited": 10,
                                    "active_invited": 8,
                                    "total_reward": 1234.56
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/invitations\/{id}\/rewards": {
        "get": {
            "tags": [
                "Invitation"
            ],
            "summary": "获取邀请关系的奖励统计",
            "description": "获取指定邀请关系的奖励统计信息，包括按来源类型聚合的奖励总额和被邀请人详情（敏感数据已脱敏）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "邀请关系ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/InvitationRewardStatsResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "invitation_id": 1,
                                    "invitee": {
                                        "uid": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                        "name": "张三",
                                        "phone": "138****8000",
                                        "email": "zh****@example.com",
                                        "status": "active",
                                        "vip_level": "bronze",
                                        "vip_level_name": "Bronze"
                                    },
                                    "total_reward": 1234.56,
                                    "currency": "USD",
                                    "status": "inactive",
                                    "reward_stats": [
                                        {
                                            "source_type": "deposit",
                                            "count": 5,
                                            "total_amount": 500
                                        },
                                        {
                                            "source_type": "bet",
                                            "count": 10,
                                            "total_amount": 734.56,
                                            "total_wager": 10000
                                        }
                                    ],
                                    "invited_at": "2024-01-01T00:00:00.000000Z"
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "邀请关系不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/invitations": {
        "get": {
            "tags": [
                "Invitation"
            ],
            "summary": "获取邀请列表",
            "description": "获取当前用户的邀请列表，支持分页",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量，默认20",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1,
                        "maximum": 100
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/InvitationListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "invitee": {
                                                "uid": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                                                "name": "张三",
                                                "phone": "138****8000",
                                                "email": "zh****@example.com",
                                                "status": "active",
                                                "vip_level": "bronze",
                                                "vip_level_name": "Bronze"
                                            },
                                            "total_reward": 100.5,
                                            "currency": "USD",
                                            "status": "inactive",
                                            "created_at": "2024-01-01T00:00:00.000000Z",
                                            "invited_at": "2024-01-01T00:00:00.000000Z"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "per_page": 20,
                                        "total": 10,
                                        "last_page": 1
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/invitations\/settings": {
        "get": {
            "tags": [
                "Invitation"
            ],
            "summary": "获取邀请设置",
            "description": "获取邀请相关的设置配置，包括充值奖励、佣金奖励、VIP升级奖励等",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/InvitationSettingsResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "deposit_bonus_starter": {
                                        "method": "fixed",
                                        "currency": "USD",
                                        "deposit_min_amount": 100,
                                        "bonus_amount": 20
                                    },
                                    "deposit_bonus_advanced": {
                                        "method": "fixed",
                                        "currency": "USD",
                                        "deposit_min_amount": 1000,
                                        "bonus_amount": 80
                                    },
                                    "commission_bonus": {
                                        "method": "ratio",
                                        "currency": "USD",
                                        "ratio": 30
                                    },
                                    "vip_upgrade_bonus": {
                                        "method": "fixed",
                                        "currency": "USD",
                                        "levels": {
                                            "1": 0.25,
                                            "2": 0.25,
                                            "3": 0.25
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
