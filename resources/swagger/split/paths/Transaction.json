{
    "\/transactions": {
        "get": {
            "tags": [
                "Transaction"
            ],
            "summary": "获取交易记录列表",
            "description": "获取当前用户的交易记录列表，支持按货币类型、交易类型、状态和时间范围筛选。时间范围仅支持：24h（最近24小时）、7d（最近7天）、30d（最近30天）",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "period",
                    "in": "query",
                    "description": "时间范围筛选，仅支持：24h（最近24小时）、7d（最近7天）、30d（最近30天）。不传此参数则查询所有记录",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "24h",
                            "7d",
                            "30d"
                        ]
                    }
                },
                {
                    "name": "currency",
                    "in": "query",
                    "description": "货币类型筛选",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "type",
                    "in": "query",
                    "description": "交易类型筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "DEPOSIT",
                            "WITHDRAWAL",
                            "WITHDRAWAL_UNFREEZE",
                            "REFUND",
                            "BET",
                            "PAYOUT"
                        ]
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "交易状态筛选",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "COMPLETED"
                        ]
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取交易记录列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/TransactionListResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": {
                                    "items": [
                                        {
                                            "id": 1,
                                            "currency": "USD",
                                            "amount": 100,
                                            "type": "DEPOSIT",
                                            "status": "COMPLETED",
                                            "transaction_time": "2024-01-01 12:00:00",
                                            "created_at": "2024-01-01 12:00:00",
                                            "notes": "Deposit via bank transfer",
                                            "related_entity_id": 123
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "last_page": 5,
                                        "total": 100
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "参数验证失败",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/transactions\/types": {
        "get": {
            "tags": [
                "Transaction"
            ],
            "summary": "获取交易类型列表",
            "description": "获取支持查询的交易类型列表",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SuccessResponse"
                            },
                            "example": {
                                "code": 0,
                                "errmsg": "Success",
                                "data": [
                                    "DEPOSIT",
                                    "WITHDRAWAL",
                                    "WITHDRAWAL_UNFREEZE",
                                    "REFUND",
                                    "BET",
                                    "PAYOUT"
                                ]
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "\/transactions\/{id}": {
        "get": {
            "tags": [
                "Transaction"
            ],
            "summary": "获取交易详情",
            "description": "根据交易ID获取交易详情",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "交易ID",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SuccessResponse"
                            },
                            "examples": {
                                "deposit": {
                                    "summary": "存款交易详情",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "id": 1,
                                            "currency": "USD",
                                            "amount": 100,
                                            "type": "DEPOSIT",
                                            "status": "COMPLETED",
                                            "transaction_time": "2024-01-01 12:00:00",
                                            "created_at": "2024-01-01 12:00:00",
                                            "updated_at": "2024-01-01 12:00:00",
                                            "notes": "Deposit via bank transfer",
                                            "related_entity_id": "123",
                                            "entity": {
                                                "type": "deposit",
                                                "data": {
                                                    "id": 123,
                                                    "order_no": "D20240101120000001",
                                                    "amount": 100,
                                                    "currency": "USD",
                                                    "status": "COMPLETED",
                                                    "created_at": "2024-01-01 12:00:00"
                                                }
                                            }
                                        }
                                    }
                                },
                                "bet": {
                                    "summary": "下注交易详情",
                                    "value": {
                                        "code": 0,
                                        "errmsg": "Success",
                                        "data": {
                                            "id": 2,
                                            "currency": "USD",
                                            "amount": 10,
                                            "type": "BET",
                                            "status": "COMPLETED",
                                            "transaction_time": "2024-01-01 14:00:00",
                                            "created_at": "2024-01-01 14:00:00",
                                            "updated_at": "2024-01-01 14:00:00",
                                            "related_entity_id": "5_abc123xyz",
                                            "entity": {
                                                "type": "order",
                                                "data": {
                                                    "id": 456,
                                                    "order_id": "01HQXYZ123456789",
                                                    "amount": 10,
                                                    "payout": 25,
                                                    "currency": "USD",
                                                    "status": "COMPLETED",
                                                    "finished_at": "2024-01-01 14:05:00",
                                                    "created_at": "2024-01-01 14:00:00",
                                                    "game": {
                                                        "id": 5,
                                                        "name": "Lucky Slots",
                                                        "thumbnail": "https:\/\/example.com\/game.jpg"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "403": {
                    "description": "无权访问",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "交易不存在",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
