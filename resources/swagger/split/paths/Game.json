    "\/games\/recent\/list": {
        "get": {
            "tags": [
                "Game"
            ],
            "summary": "获取用户最近游玩的游戏列表",
            "description": "获取当前登录用户最近游玩的游戏列表（分页），支持按最近游玩时间、游玩次数、最大奖励倍数排序",
            "security": [
                {
                    "bearerAuth": []
                }
            ],
            "parameters": [
                {
                    "name": "Locale",
                    "in": "header",
                    "description": "语言代码",
                    "schema": {
                        "type": "string",
                        "default": "en"
                    }
                },
                {
                    "name": "sort",
                    "in": "query",
                    "description": "排序方式：recent(最近游玩)、play_count(游玩次数)、max_multiplier(最大倍数)",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "recent",
                            "play_count",
                            "max_multiplier"
                        ],
                        "default": "recent"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "schema": {
                        "type": "integer",
                        "default": 1,
                        "minimum": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页数量",
                    "schema": {
                        "type": "integer",
                        "default": 20,
                        "minimum": 1,
                        "maximum": 100
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "获取最近游玩游戏列表成功",
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/RecentGameListResponse"
                            },
